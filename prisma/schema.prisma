
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Resource {
  id          String   @id @default(uuid())
  originalUrl String   @db.Text
  shortCode   String   @unique 
  ownerId     String
  publicId    String?  
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}